################################################################################
# begetctl 单元测试配置
################################################################################

config("begetctl_utest_config") {
  visibility = [ ":*" ]

  cflags = [
    "-Wno-implicit-fallthrough",
    "-Wno-unused-function",
    "-Wno-unused-private-field",
    "-Wno-error=unused-function",
    "-Dprivate=public",
    "-Dprotected=public",
  ]

  cflags_cc = [
    "-Wno-implicit-fallthrough",
    "-fexceptions",
    "-Wno-error=unused-function",
  ]
}

